{
  "name": "searchbox",
  "type": "module",
  "version": "0.1.0",
  "description": "A quick search component for pizza/easysearch, inspired by algolia/docsearch.",
  "license": "MIT or Apache-2.0",
  "keywords": [
    "pizza",
    "search",
    "docsearch",
    "autocomplete",
    "docs",
    "quicksearch",
    "quicksearchbar"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": "./dist/index.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE_*",
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:server": "vite build && mkdir -p ../../../.public/widgets/searchbox && cp dist/index.css dist/index.js ../../../.public/widgets/searchbox",
    "dev": "vite",
    "demo": "cd dist && http-server",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,json,html,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"./**/*.{js,jsx,ts,tsx,json,html,css}\" --ignore-path .gitignore",
    "prepublishOnly": "pnpm build",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@infinilabs/search-chat": "^1.3.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "searchbox": "link:"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "http-server": "^14.1.1",
    "prettier": "3.3.2",
    "typescript": "^5.5.2",
    "vite": "7.2.4",
    "vite-plugin-svgr": "^4.3.0"
  }
}
